# Vael — Environment Configuration
# Copy this file to .env and fill in real values from Google Cloud Console.
# See docs/GOOGLE_CLOUD_SETUP.md for how to obtain these.
#
# NEVER commit .env to git.

# ─── Google OAuth Client IDs ─────────────────────────────────────────────────
# From: Google Cloud Console → APIs & Services → Credentials

# iOS OAuth Client ID (from GoogleService-Info.plist → CLIENT_ID)
GOOGLE_CLIENT_ID_IOS=your-ios-client-id.apps.googleusercontent.com

# iOS Reversed Client ID (from GoogleService-Info.plist → REVERSED_CLIENT_ID)
# Used as URL scheme in Info.plist for OAuth redirect
GOOGLE_REVERSED_CLIENT_ID_IOS=com.googleusercontent.apps.your-ios-client-id

# Android OAuth Client ID (registered with your debug/release SHA-1)
GOOGLE_CLIENT_ID_ANDROID=your-android-client-id.apps.googleusercontent.com

# macOS OAuth Client ID (Desktop application type)
GOOGLE_CLIENT_ID_MACOS=your-macos-client-id.apps.googleusercontent.com

# macOS OAuth Client Secret (Desktop application type)
GOOGLE_CLIENT_SECRET_MACOS=your-macos-client-secret

# ─── Android Signing ─────────────────────────────────────────────────────────
# Only needed for release builds (Play Store submission)

ANDROID_KEYSTORE_PATH=~/vael-upload-keystore.jks
ANDROID_KEYSTORE_PASSWORD=
ANDROID_KEY_ALIAS=vael-upload
ANDROID_KEY_PASSWORD=
